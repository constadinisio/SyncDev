{
  "name": "collab-editor",
  "private": true,
  "workspaces": [
    "apps/web",
    "services/collab"
  ],
  "scripts": {
    "dev:web": "npm -w apps/web run dev",
    "dev:collab": "npm -w services/collab run dev",
    "dev": "concurrently \"npm run dev:collab\" \"npm run dev:web\"",
    "build": "npm -w services/collab run build && npm -w apps/web run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.1"
  }
}
