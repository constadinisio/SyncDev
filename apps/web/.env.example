# Web app configuration
# Copy to .env.local and adjust.

# --- Authentication (Auth.js / NextAuth v5) ---
# Master switch. When "true", pages require login and collab requests are signed.
# Leave unset/false for frictionless local development.
AUTH_ENABLED=false
# Exposed to the browser; must mirror AUTH_ENABLED so the client attaches tokens.
NEXT_PUBLIC_AUTH_ENABLED=false

# Required when AUTH_ENABLED=true. Generate with: openssl rand -base64 33
AUTH_SECRET=

# GitHub OAuth app credentials (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Shared HS256 secret (>=32 chars) used to sign tokens for the collab service.
# MUST match the collab service's COLLAB_JWT_SECRET.
COLLAB_JWT_SECRET=

# --- Collab service endpoints (optional; auto-detected from hostname) ---
# NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000
