# Collab service configuration
# Copy to .env and adjust. Variables are validated at startup (fail-fast).

# development | production | test
NODE_ENV=development

# HTTP/WebSocket listen address
PORT=4000
HOST=0.0.0.0

# REQUIRED in production: comma-separated list of allowed browser origins.
# In development, defaults to http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# Persistence
SNAPSHOT_DIR=./storage/snapshots
SNAPSHOT_DEBOUNCE_MS=2000
SNAPSHOT_INTERVAL_MS=30000
ROOM_GRACE_PERIOD_MS=30000

# Logging: trace | debug | info | warn | error
LOG_LEVEL=debug

# Rate limiting for sensitive endpoints (terminal, clone, upload, scan)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Authentication
# Enforced automatically in production; set explicitly to test locally.
AUTH_ENFORCED=false
# Shared HS256 secret (>=32 chars) used to verify tokens minted by the web app.
# MUST match the web app's COLLAB_JWT_SECRET. Required when auth is enforced.
COLLAB_JWT_SECRET=
# Optional: override the project membership store location.
# MEMBERSHIPS_FILE=./storage/memberships.json
