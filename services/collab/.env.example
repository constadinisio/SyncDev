# Collab service configuration
# Copy to .env and adjust. Variables are validated at startup (fail-fast).

# development | production | test
NODE_ENV=development

# HTTP/WebSocket listen address
PORT=4000
HOST=0.0.0.0

# REQUIRED in production: comma-separated list of allowed browser origins.
# In development, defaults to http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# Persistence
SNAPSHOT_DIR=./storage/snapshots
SNAPSHOT_DEBOUNCE_MS=2000
SNAPSHOT_INTERVAL_MS=30000
ROOM_GRACE_PERIOD_MS=30000

# Logging: trace | debug | info | warn | error
LOG_LEVEL=debug

# Error tracking (optional). Leave empty to disable Sentry.
SENTRY_DSN=

# Rate limiting for sensitive endpoints (terminal, clone, upload, scan)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Authentication
# Enforced automatically in production; set explicitly to test locally.
AUTH_ENFORCED=false
# Shared HS256 secret (>=32 chars) used to verify tokens minted by the web app.
# MUST match the web app's COLLAB_JWT_SECRET. Required when auth is enforced.
COLLAB_JWT_SECRET=
# Optional: override the project membership store location.
# MEMBERSHIPS_FILE=./storage/memberships.json

# Terminal sandbox
# Run terminal commands inside an ephemeral Docker container (enabled in
# production). Requires the Docker daemon to be reachable by this service.
TERMINAL_SANDBOX_DOCKER=false
SANDBOX_IMAGE=node:20-bookworm-slim
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1
SANDBOX_PIDS_LIMIT=512
# Container network: "bridge" (outbound allowed, needed for npm/git) or "none".
SANDBOX_NETWORK=bridge
# Only when THIS service runs in a container and talks to the host Docker
# socket: the host path of the workspaces dir, so sibling-container bind mounts
# resolve correctly. Leave empty when running on the host directly.
# SANDBOX_HOST_WORKSPACE_BASE=/srv/syncdev/data/workspaces

# Reproducible environments (devcontainers)
# Run terminal commands in a persistent per-project container (default in prod).
ENVIRONMENTS_ENABLED=false
DEVCONTAINER_DEFAULT_IMAGE=mcr.microsoft.com/devcontainers/javascript-node:20
MAX_ACTIVE_ENVIRONMENTS=5
ENV_IDLE_MS=600000
