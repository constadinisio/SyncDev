# Production compose configuration. Copy to infra/.env and fill in.
# Used by docker-compose.prod.yml.

# Public domain (DNS must point at this server). Caddy gets TLS for it.
SYNCDEV_DOMAIN=syncdev.example.com

# Host directory for persistent data (snapshots, workspaces). Absolute path.
SYNCDEV_DATA_DIR=/srv/syncdev/data

# --- Secrets (generate fresh, never commit) ---
# Auth.js session secret:        openssl rand -base64 33
AUTH_SECRET=
# Shared collab token secret (>=32 chars), same value used by web and collab:
#                                openssl rand -hex 32
COLLAB_JWT_SECRET=

# GitHub OAuth app (https://github.com/settings/developers)
#   Homepage URL:      https://syncdev.example.com
#   Callback URL:      https://syncdev.example.com/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
